---
const palette = [
  '#ffe0b2', '#ffcdd2', '#f8bbd0', '#c8e6c9',
  '#b3e5fc', '#e1bee7', '#fff9c4', '#ffccbc',
];

interface Bubble {
  size: number;
  left: number;
  color: string;
  duration: number;
  delay: number;
  shape: 'circle' | 'star' | 'heart';
}

const shapes: Bubble['shape'][] = ['circle', 'circle', 'circle', 'star', 'heart'];

const bubbles: Bubble[] = Array.from({ length: 14 }, () => ({
  size: 5 + Math.random() * 22,
  left: Math.random() * 100,
  color: palette[Math.floor(Math.random() * palette.length)],
  duration: 18 + Math.random() * 22,
  delay: Math.random() * 28,
  shape: shapes[Math.floor(Math.random() * shapes.length)],
}));
---

<div class="bubbles">
  {bubbles.map((b) => (
    <div
      class={`bubble bubble--${b.shape}`}
      style={`
        width: ${b.size}px;
        height: ${b.size}px;
        left: ${b.left}%;
        background: ${b.shape === 'circle' ? b.color : 'none'};
        ${b.shape === 'circle' ? '' : `color: ${b.color};`}
        animation-duration: ${b.duration}s;
        animation-delay: ${b.delay}s;
      `}
    >
      {b.shape === 'star' && (
        <svg viewBox="0 0 24 24" fill="currentColor" width="100%" height="100%">
          <path d="M12 0l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/>
        </svg>
      )}
      {b.shape === 'heart' && (
        <svg viewBox="0 0 24 24" fill="currentColor" width="100%" height="100%">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      )}
    </div>
  ))}
</div>

<style>
  .bubbles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .bubble {
    position: absolute;
    opacity: 0;
    animation: float linear infinite;
  }
  .bubble--circle {
    border-radius: 50%;
    opacity: var(--bubble-opacity, .4);
  }
  .bubble--star,
  .bubble--heart {
    opacity: 0;
  }
  @keyframes float {
    0%   { transform: translateY(110vh) scale(0) rotate(0deg); opacity: 0; }
    8%   { opacity: var(--bubble-opacity, .4); }
    92%  { opacity: var(--bubble-opacity, .4); }
    100% { transform: translateY(-10vh) scale(1) rotate(180deg); opacity: 0; }
  }
</style>
